  "text_instructions": [
    "This space is designed to investigate an 18-point drop in customer satisfaction scores during Q2 2025. Use it to explore delivery performance by fulfillment partner, product weight class, and region.",
    "Data covers Q2 2025 (April 1 \u2013 June 30, 2025).",
    "Round all currency values to 2 decimal places and all percentages to 2 decimal places.",
    "When users ask about delivery performance without specifying a partner, show all partners. When they mention a product category without specifying which one, ask: 'Which product category would you like to focus on?'",
    "Glossary: 3PL = Third-Party Logistics partner. CSAT = Customer Satisfaction. SLA = Service-Level Agreement. On-time = actual_delivery_date <= promised_delivery_date. Late = actual_delivery_date > promised_delivery_date. COO = Chief Operating Officer."
  ],
  "example_question_sqls": [
    {
      "question": "What is the on-time delivery rate by fulfillment partner?",
      "sql": "SELECT\n  fp.partner_id,\n  fp.partner_name,\n  fp.specialization,\n  COUNT(*) AS total_shipments,\n  SUM(CASE WHEN s.delivery_status = 'Late' THEN 1 ELSE 0 END) AS late_count,\n  ROUND(SUM(CASE WHEN s.delivery_status != 'Late' THEN 1.0 ELSE 0 END) / COUNT(*) * 100, 2) AS on_time_pct,\n  fp.contract_sla_pct\nFROM ops_shipments.`default`.shipments s\nJOIN ops_shipments.`default`.fulfillment_partners fp ON s.fulfillment_partner_id = fp.partner_id\nGROUP BY fp.partner_id, fp.partner_name, fp.specialization, fp.contract_sla_pct\nORDER BY on_time_pct ASC"
    },
    {
      "question": "How do CSAT scores correlate with delivery status?",
      "sql": "SELECT\n  s.delivery_status,\n  ROUND(AVG(cs.satisfaction_score), 2) AS avg_csat,\n  COUNT(*) AS response_count\nFROM ops_shipments.`default`.csat_responses cs\nJOIN ops_shipments.`default`.shipments s ON cs.order_id = s.order_id\nGROUP BY s.delivery_status\nORDER BY avg_csat"
    },
    {
      "question": "What is the late delivery rate by product weight class?",
      "sql": "SELECT\n  p.weight_class,\n  COUNT(*) AS total_shipments,\n  SUM(CASE WHEN s.delivery_status = 'Late' THEN 1 ELSE 0 END) AS late_count,\n  ROUND(SUM(CASE WHEN s.delivery_status = 'Late' THEN 1.0 ELSE 0 END) / COUNT(*) * 100, 2) AS late_rate_pct\nFROM ops_shipments.`default`.shipments s\nJOIN ops_shipments.`default`.orders o ON s.order_id = o.order_id\nJOIN ops_shipments.`default`.products p ON o.product_id = p.product_id\nGROUP BY p.weight_class\nORDER BY late_rate_pct DESC"
    },
    {
      "question": "What share of low-CSAT complaints come from FP-004?",
      "sql": "SELECT\n  fp.partner_id,\n  fp.partner_name,\n  COUNT(*) AS low_csat_responses,\n  ROUND(COUNT(*) * 100.0 / SUM(COUNT(*)) OVER (), 2) AS pct_of_all_low_csat\nFROM ops_shipments.`default`.csat_responses cs\nJOIN ops_shipments.`default`.shipments s ON cs.order_id = s.order_id\nJOIN ops_shipments.`default`.fulfillment_partners fp ON s.fulfillment_partner_id = fp.partner_id\nWHERE cs.satisfaction_score <= 5\nGROUP BY fp.partner_id, fp.partner_name\nORDER BY low_csat_responses DESC"
    }
  ],
  "sql_snippets": {
    "filters": [
      {
        "display_name": "Late Deliveries Only",
        "sql": "ops_shipments.`default`.shipments.delivery_status = 'Late'"
      },
      {
        "display_name": "Partner FP-004",
        "sql": "ops_shipments.`default`.shipments.fulfillment_partner_id = 'FP-004'"
      },
      {
        "display_name": "Heavy/Oversized Products",
        "sql": "ops_shipments.`default`.products.weight_class IN ('Heavy', 'Oversized')"
      },
      {
        "display_name": "Low CSAT (score <= 5)",
        "sql": "ops_shipments.`default`.csat_responses.satisfaction_score <= 5"
      }
    ],
    "measures": [
      {
        "display_name": "On-Time %",
        "sql": "ROUND(SUM(CASE WHEN ops_shipments.`default`.shipments.delivery_status != 'Late' THEN 1.0 ELSE 0 END) / COUNT(*) * 100, 2)"
      },
      {
        "display_name": "Avg CSAT Score",
        "sql": "ROUND(AVG(ops_shipments.`default`.csat_responses.satisfaction_score), 2)"
      },
      {
        "display_name": "Late Delivery Count",
        "sql": "SUM(CASE WHEN ops_shipments.`default`.shipments.delivery_status = 'Late' THEN 1 ELSE 0 END)"
      },
      {
        "display_name": "Total Orders",
        "sql": "COUNT(DISTINCT ops_shipments.`default`.orders.order_id)"
      }
    ]
  }
